# Accelo deployment subdomain (e.g. "yourcompany" for yourcompany.accelo.com)
ACCELO_DEPLOYMENT=
# Value of the AFFINITYLIVE cookie from a logged-in browser session.
# Chrome DevTools -> Application -> Cookies -> https://<deployment>.accelo.com -> AFFINITYLIVE -> copy Value.
# This is a session cookie and will expire; re-copy it when requests start returning SESSION_EXPIRED.
ACCELO_SESSION_COOKIE=
